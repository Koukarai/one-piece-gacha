# Public — safe to expose to the browser bundle.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with PUBLIC_, never send to the client.
# Used by src/lib/supabaseServer.ts for server-authoritative game logic
# (summon, training, battle rewards, mail claims).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
