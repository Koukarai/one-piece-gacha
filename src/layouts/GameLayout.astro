---
import "../app.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>ONE PIECE: GRAND LINE</title>
  </head>
  <body class="bg-[#050505] text-white font-space overflow-x-hidden">
    
    <div class="flex min-h-screen">
      <!-- SIDEBAR -->
      <aside class="w-64 glass-dark border-r border-white/5 flex flex-col p-6 fixed h-full z-50">
        <div class="mb-12">
          <h1 class="font-teko text-5xl text-gradient-gold tracking-tighter leading-none">GRAND LINE</h1>
          <p class="text-gray-500 text-[10px] font-space tracking-[0.3em] uppercase mt-1 opacity-70">Tactics & Gacha</p>
        </div>

        <nav class="flex flex-col gap-2 flex-1">
          <a href="/" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-all duration-300 group">
             <div class="w-1 h-6 bg-gold-500 scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
            <span class="font-teko text-2xl tracking-wide group-hover:text-gold-400 -ml-5 transition-all group-hover:ml-0">HOME BASE</span>
          </a>

          <a href="/inbox" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-all duration-300 group">
            <div class="w-1 h-6 bg-gold-500 scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
            <span class="font-teko text-2xl tracking-wide group-hover:text-gold-400 -ml-5 transition-all group-hover:ml-0">INBOX</span>
          </a>

          <a href="/summon" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-all duration-300 group">
            <div class="w-1 h-6 bg-gold-500 scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
            <span class="font-teko text-2xl tracking-wide group-hover:text-gold-400 -ml-5 transition-all group-hover:ml-0">SUMMON</span>
          </a>

          <a href="/barracks" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-all duration-300 group">
            <div class="w-1 h-6 bg-gold-500 scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
            <span class="font-teko text-2xl tracking-wide group-hover:text-gold-400 -ml-5 transition-all group-hover:ml-0">BARRACKS</span>
          </a>

          <a href="/arena" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-all duration-300 group">
            <div class="w-1 h-6 bg-red-600 scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
            <span class="font-teko text-2xl tracking-wide text-red-500 group-hover:text-red-400 -ml-5 transition-all group-hover:ml-0">ARENA</span>
          </a>

          <a href="/leaderboard" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-all duration-300 group">
            <div class="w-1 h-6 bg-gold-500 scale-y-0 group-hover:scale-y-100 transition-transform origin-top"></div>
            <span class="font-teko text-2xl tracking-wide group-hover:text-gold-400 -ml-5 transition-all group-hover:ml-0">BOUNTY BOARD</span>
          </a>
          
          <!-- LOGOUT BUTTON -->
          <button id="logout-btn" class="flex items-center gap-4 p-3 rounded-xl hover:bg-red-950/20 transition-all duration-300 group mt-auto border-t border-white/5 pt-4 w-full text-left">
            <span class="font-teko text-2xl tracking-wide text-gray-500 group-hover:text-red-400">LOGOUT</span>
          </button>
        </nav>

        <!-- REAL USER PROFILE DATA -->
        <div class="mt-6 pt-6 border-t border-white/5" id="user-profile-section">
          <div class="flex items-center gap-4 p-2 rounded-2xl glass-dark hover:border-white/10 transition-colors">
            <div class="w-12 h-12 rounded-2xl bg-gray-900 border border-white/10 overflow-hidden shadow-inner">
               <img id="sidebar-avatar" src="https://api.dicebear.com/7.x/adventurer/svg?seed=Felix" alt="avatar" class="w-full h-full object-cover"/>
            </div>
            <div class="flex-1 min-w-0">
              <p id="profile-email" class="font-teko text-xl leading-none text-gray-200 truncate">Loading...</p>
              <div class="flex items-center gap-1.5 mt-1">
                 <div class="w-2 h-2 rounded-full bg-gold-500 shadow-[0_0_8px_rgba(230, 162, 60,0.5)]"></div>
                 <p id="profile-berries" class="text-[10px] font-space font-bold text-gold-500 uppercase tracking-tighter">...</p>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- MAIN CONTENT -->
      <main class="flex-1 ml-64 p-10 min-h-screen relative">
        <div class="absolute inset-0 bg-gradient-to-br from-gold-500/5 via-transparent to-red-500/5 pointer-events-none"></div>
        <div class="relative z-10">
          <slot />
        </div>
      </main>
    </div>

    <script>
      import { supabase } from "../lib/supabase";
      import { callApi } from "../lib/apiClient";

      function showDailyLoginToast(streak: number, reward: number) {
        const toast = document.createElement('div');
        toast.className = 'fixed top-6 right-6 z-[200] glass-dark border border-gold-500/40 rounded-2xl px-6 py-4 text-white shadow-2xl transition-all duration-500';
        toast.innerHTML = `
          <div class="font-teko text-2xl text-gold-400 uppercase leading-none mb-1">Day ${streak} Login Bonus</div>
          <div class="text-xs text-gray-400 font-space uppercase tracking-widest">+${reward} Berries — check your Inbox</div>
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateY(-10px)';
          setTimeout(() => toast.remove(), 500);
        }, 4000);
      }

      async function claimDailyLogin() {
        try {
          const result = await callApi('/api/daily/login');
          if (result.claimed) showDailyLoginToast(result.streak, result.reward);
        } catch {
          // Not critical — a background reward claim failing silently is fine.
        }
      }

      async function loadProfile() {
        const { data: { user } } = await supabase.auth.getUser();

        if (!user) {
          if (window.location.pathname !== '/login') {
             window.location.href = '/login';
          }
          return;
        }

        claimDailyLogin();

        const { data: profile, error } = await supabase
          .from('profiles')
          .select('username, berries, avatar_url')
          .eq('id', user.id)
          .single();
        
        if (error) {
          const emailEl = document.getElementById('profile-email');
          if (emailEl) emailEl.innerText = "Captain";
          return;
        }

        if (profile) {
          const emailEl = document.getElementById('profile-email');
          const berryEl = document.getElementById('profile-berries');
          
          if (profile.avatar_url) {
             const avatarImg = document.getElementById('sidebar-avatar');
             if (avatarImg) (avatarImg as HTMLImageElement).src = profile.avatar_url;
          }

          let displayName = profile.username;
          if (displayName && (displayName.includes("@") || displayName.length > 15)) {
             displayName = "Captain " + user.id.slice(0, 4).toUpperCase();
          }

          if (emailEl) emailEl.innerText = displayName || "Captain";
          if (berryEl) berryEl.innerText = `${profile.berries.toLocaleString()} BERRY`;
        }
      }

      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.href = '/login';
        });
      }

      loadProfile();
    </script>
  </body>
</html>