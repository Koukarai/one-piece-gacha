---
import GameLayout from "../layouts/GameLayout.astro";
---

<GameLayout>
  <div class="max-w-6xl mx-auto pt-6">
    
    <!-- HERO SECTION -->
    <div class="relative w-full h-80 rounded-[2rem] overflow-hidden border border-white/5 mb-10 group shadow-2xl">
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&q=80&w=2000')] bg-cover bg-center group-hover:scale-105 transition-transform duration-1000"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/60 to-transparent z-10"></div>
      <div class="absolute inset-0 bg-gold-900/10 group-hover:bg-gold-900/20 transition-colors duration-500 z-10"></div>
      
      <div class="absolute bottom-0 left-0 p-12 z-20 w-full md:w-2/3">
        <div class="flex items-center gap-2 mb-4">
           <span class="px-3 py-1 bg-gold-500/20 border border-gold-500/30 text-gold-500 text-[10px] font-space font-black tracking-widest uppercase rounded-full backdrop-blur-md">STATUS: ONLINE</span>
           <span class="px-3 py-1 bg-white/5 border border-white/10 text-gray-400 text-[10px] font-space font-black tracking-widest uppercase rounded-full backdrop-blur-md">REGION: GRAND LINE</span>
        </div>
        <h1 class="font-teko text-7xl text-white mb-2 leading-[0.8] tracking-tighter">WELCOME BACK, <br/><span class="text-gradient-gold">CAPTAIN.</span></h1>
        <p class="font-space text-gray-400 max-w-md text-sm leading-relaxed mt-4 opacity-80">Your crew is rested and the Log Pose is set. New bounties have been posted in the Arena. Shall we set sail?</p>
        
        <div class="flex gap-4 mt-8">
          <a href="/summon" class="px-8 py-3 bg-gold-400 text-black font-teko text-2xl rounded-xl hover:bg-gold-300 transition-all shadow-[0_0_20px_rgba(230, 162, 60,0.3)] hover:scale-105 active:scale-95">
            RECRUIT NAKAMA
          </a>
          
          <a href="/arena" class="px-8 py-3 glass text-white font-teko text-2xl rounded-xl hover:bg-white/10 transition-all hover:scale-105 active:scale-95">
            ENTER ARENA
          </a>
        </div>
      </div>
    </div>

    <!-- STATS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <div class="glass-dark border border-white/5 p-8 rounded-3xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gold-500/5 blur-3xl -mr-16 -mt-16 group-hover:bg-gold-500/10 transition-colors"></div>
        <h3 class="font-teko text-3xl text-gray-500 mb-6 tracking-wide uppercase">CURRENT BOUNTY</h3>
        <div class="flex items-baseline gap-2">
          <p id="dashboard-bounty" class="text-6xl font-black text-white font-teko tracking-tighter">---</p>
          <span class="text-gold-500 font-teko text-2xl">฿</span>
        </div>
        <div class="mt-6 flex items-center gap-2">
           <div class="px-2 py-0.5 bg-green-500/10 text-green-400 text-[10px] font-bold rounded">+12.5%</div>
           <span class="text-[10px] text-gray-600 uppercase font-space tracking-wider font-bold">vs last week</span>
        </div>
      </div>

      <div class="glass-dark border border-white/5 p-8 rounded-3xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 blur-3xl -mr-16 -mt-16 group-hover:bg-blue-500/10 transition-colors"></div>
        <h3 class="font-teko text-3xl text-gray-500 mb-6 tracking-wide uppercase">CREW SIZE</h3>
        <p id="crew-count" class="text-6xl font-black text-white font-teko tracking-tighter">...</p>
        <div class="mt-6 flex -space-x-3 overflow-hidden opacity-50 grayscale group-hover:grayscale-0 transition-all duration-500">
           <div class="inline-block h-8 w-8 rounded-full ring-2 ring-black bg-gray-800"></div>
           <div class="inline-block h-8 w-8 rounded-full ring-2 ring-black bg-gray-700"></div>
           <div class="inline-block h-8 w-8 rounded-full ring-2 ring-black bg-gray-800"></div>
           <div class="inline-block h-8 w-8 rounded-full ring-2 ring-black bg-gray-700 flex items-center justify-center text-[10px] text-white">+</div>
        </div>
      </div>

      <div class="glass-dark border border-white/5 p-8 rounded-3xl relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-red-500/5 blur-3xl -mr-16 -mt-16 group-hover:bg-red-500/10 transition-colors"></div>
        <h3 class="font-teko text-3xl text-gray-500 mb-6 tracking-wide uppercase">SERVER STATUS</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-4 border-l-2 border-gold-500 pl-4 py-1">
            <div>
              <span class="text-[10px] text-gold-500 font-black font-space tracking-widest block mb-1">EVENT LIVE</span>
              <p class="text-sm text-gray-200 font-space font-medium leading-tight">Marineford Raid starts in 2h 15m</p>
            </div>
          </div>
          <div class="flex items-start gap-4 border-l-2 border-white/10 pl-4 py-1">
            <div>
              <span class="text-[10px] text-gray-500 font-black font-space tracking-widest block mb-1">PATCH 1.4.2</span>
              <p class="text-sm text-gray-400 font-space leading-tight">Fixed Ace's Flame Emperor AOE</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
  
  <script>
    import { supabase } from "../lib/supabase";
    
    async function updateDashboard() {
       const { data: { user } } = await supabase.auth.getUser();
       if(user) {
          const { data: profile } = await supabase.from('profiles').select('berries').eq('id', user.id).single();
          if(profile) {
             const el = document.getElementById('dashboard-bounty');
             if(el) {
                // Animated counter simple version
                el.innerText = profile.berries.toLocaleString();
             }
          }

          const { count } = await supabase.from('inventory').select('*', { count: 'exact', head: true }).eq('user_id', user.id);
          
          const countEl = document.getElementById('crew-count');
          if(countEl) countEl.innerText = (count || "0").toString();
       }
    }
    updateDashboard();
  </script>
</GameLayout>