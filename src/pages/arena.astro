---
import GameLayout from "../layouts/GameLayout.astro";
---

<GameLayout>
  <div id="battle-scene" class="max-w-6xl mx-auto min-h-[85vh] flex flex-col items-center justify-center relative p-6 transition-all duration-500">

    <!-- TOP HUD -->
    <div class="absolute top-0 w-full flex justify-between items-center p-6 glass-dark z-20 rounded-3xl mt-4 border border-white/5">
        <div class="flex items-center gap-6">
            <div class="h-12 w-1 bg-gradient-to-b from-gold-500 to-transparent rounded-full"></div>
            <div>
                <h1 class="font-teko text-5xl text-white uppercase tracking-tight leading-none">BATTLE ARENA</h1>
                <p class="text-[10px] text-gray-500 font-space font-black tracking-[0.3em] uppercase opacity-70">Server-Resolved Combat</p>
            </div>
        </div>

        <div class="flex flex-col items-center">
            <div id="turn-indicator" class="font-teko text-4xl text-gold-500 uppercase tracking-widest drop-shadow-[0_0_15px_rgba(230, 162, 60,0.5)]">
                AWAITING ORDERS
            </div>
        </div>

        <div class="flex items-center gap-6">
             <div class="text-right">
                <p class="text-[10px] text-gray-500 font-space font-black tracking-widest uppercase">Energy</p>
                <div class="flex items-baseline justify-end gap-1">
                    <span id="energy-current" class="text-5xl font-teko text-white leading-none">--</span>
                    <span class="text-gray-600 font-teko text-xl">/ <span id="energy-max">--</span></span>
                </div>
                <p id="energy-regen-hint" class="text-[9px] text-gray-600 uppercase tracking-widest mt-1"></p>
             </div>
             <div class="text-right">
                <p class="text-[10px] text-gray-500 font-space font-black tracking-widest uppercase">Potential Reward</p>
                <div class="flex items-baseline justify-end gap-1">
                    <span id="reward-preview" class="text-5xl font-teko text-white leading-none">250</span>
                    <span class="text-gold-500 font-teko text-xl">฿</span>
                </div>
             </div>
        </div>
    </div>

    <!-- BATTLEFIELD -->
    <div class="flex flex-col md:flex-row w-full gap-12 mt-32 mb-12 relative z-10">

        <!-- PLAYER SIDE -->
        <div class="flex-1 flex flex-col items-center">
            <div class="mb-6 flex items-center gap-3">
                <span class="h-[1px] w-12 bg-white/10"></span>
                <h2 class="text-white/40 font-teko text-2xl tracking-[0.2em] uppercase">YOUR CREW</h2>
                <span class="h-[1px] w-12 bg-white/10"></span>
            </div>
            <div id="player-squad" class="grid grid-cols-3 gap-6 w-full justify-items-center">
                <!-- Cards injected here -->
            </div>
        </div>

        <!-- VS DIVIDER -->
        <div class="flex items-center justify-center">
            <div class="relative group">
                <div class="absolute inset-0 bg-red-500 blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                <div class="w-16 h-16 rounded-2xl glass-dark border border-red-500/30 flex items-center justify-center text-red-500 font-teko text-3xl italic rotate-45 group-hover:rotate-180 transition-transform duration-700">
                    <span class="-rotate-45 group-hover:-rotate-180 transition-transform duration-700">VS</span>
                </div>
            </div>
        </div>

        <!-- ENEMY SIDE -->
        <div class="flex-1 flex flex-col items-center">
            <div class="mb-6 flex items-center gap-3">
                <span class="h-[1px] w-12 bg-red-900/20"></span>
                <h2 class="text-red-500/40 font-teko text-2xl tracking-[0.2em] uppercase font-bold">TARGETS</h2>
                <span class="h-[1px] w-12 bg-red-900/20"></span>
            </div>
            <div id="enemy-squad" class="grid grid-cols-3 gap-6 w-full justify-items-center">
                <!-- Cards injected here -->
            </div>
        </div>
    </div>

    <!-- COMMAND CENTER -->
    <div class="w-full max-w-5xl glass-dark border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col md:flex-row h-64 shadow-2xl relative">

        <!-- BATTLE LOG -->
        <div id="battle-log" class="flex-1 p-6 font-space text-[10px] overflow-y-auto space-y-2 scrollbar-hide border-r border-white/5 bg-black/40">
            <div class="text-gold-500/40 font-bold tracking-widest uppercase">BATTLE LOG</div>
            <div class="text-gray-500">SYSTEM: STANDING BY...</div>
        </div>

        <!-- DEPLOY PANEL -->
        <div id="deploy-panel" class="w-1/3 p-6 flex flex-col bg-white/[0.02] gap-3">
            <div id="stage-list" class="flex-1 overflow-y-auto space-y-2 pr-1">
                <!-- Stage rows injected here -->
            </div>
            <button id="btn-start-battle" class="px-10 py-4 bg-gold-400 text-black font-teko text-3xl rounded-2xl hover:bg-gold-300 transition-all hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(230, 162, 60,0.3)] disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:scale-100">
                DEPLOY SQUAD
            </button>
        </div>
    </div>

    <!-- RESULTS OVERLAY -->
    <div id="results-overlay" class="fixed inset-0 z-[100] glass-dark flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-700">
        <h2 id="result-title" class="font-teko text-[12rem] text-white leading-none tracking-tighter italic">VICTORY</h2>
        <p id="result-subtitle" class="font-space text-gray-400 tracking-[0.5em] uppercase -mt-8 mb-12">The Grand Line Welcomes You</p>
        <button onclick="window.location.reload()" class="px-12 py-4 bg-gold-400 text-black font-teko text-3xl rounded-2xl hover:bg-gold-300 transition-all hover:scale-110 shadow-[0_0_50px_rgba(230, 162, 60,0.3)]">RETURN TO BASE</button>
    </div>

  </div>

  <script>
    import { callApi } from "../lib/apiClient";
    import { supabase } from "../lib/supabase";
    import { computeRegen } from "../game/energy";
    import { STAGES, isStageUnlocked } from "../game/stages";
    import type { BattleEvent, PublicUnit } from "../game/battleEngine";

    interface RenderUnit extends PublicUnit {
        currentHp: number;
        isDead: boolean;
    }

    let playerSquad: RenderUnit[] = [];
    let enemySquad: RenderUnit[] = [];
    let currentEnergy = 0;
    let highestStageCleared = 0;
    let selectedStageId = 1;

    function renderEnergy(current: number, max: number) {
        currentEnergy = current;
        const currentEl = document.getElementById('energy-current');
        const maxEl = document.getElementById('energy-max');
        if (currentEl) currentEl.innerText = `${current}`;
        if (maxEl) maxEl.innerText = `${max}`;
        updateDeployButton();
    }

    function updateDeployButton() {
        const btn = document.getElementById('btn-start-battle') as HTMLButtonElement | null;
        const hintEl = document.getElementById('energy-regen-hint');
        const stage = STAGES.find((s) => s.id === selectedStageId)!;
        const rewardEl = document.getElementById('reward-preview');
        if (rewardEl) rewardEl.innerText = `${stage.winReward}`;

        const locked = !isStageUnlocked(selectedStageId, highestStageCleared);
        const insufficient = currentEnergy < stage.energyCost;

        if (hintEl) hintEl.innerText = insufficient ? `NEED ${stage.energyCost} — REGENERATES OVER TIME` : '';
        if (btn) btn.disabled = locked || insufficient;
    }

    function renderStageList() {
        const list = document.getElementById('stage-list');
        if (!list) return;
        list.innerHTML = STAGES.map((stage) => {
            const unlocked = isStageUnlocked(stage.id, highestStageCleared);
            const cleared = stage.id <= highestStageCleared;
            const selected = stage.id === selectedStageId;
            const borderClass = selected ? 'border-gold-400 bg-white/5' : 'border-white/5';
            const opacityClass = unlocked ? '' : 'opacity-40 cursor-not-allowed';
            return `
                <button data-stage-id="${stage.id}" class="stage-row w-full text-left p-3 rounded-xl border ${borderClass} ${opacityClass} transition-all hover:border-gold-500/50">
                    <div class="flex justify-between items-center">
                        <span class="font-teko text-xl text-white uppercase tracking-wide">${stage.name}</span>
                        ${cleared ? '<span class="text-[9px] text-green-400 uppercase font-black">CLEARED</span>' : ''}
                        ${!unlocked ? '<span class="text-[9px] text-gray-500 uppercase font-black">LOCKED</span>' : ''}
                    </div>
                    <div class="flex justify-between text-[9px] text-gray-500 uppercase tracking-widest mt-1">
                        <span>${stage.energyCost} Energy</span>
                        <span class="text-gold-500">+${stage.winReward} ฿</span>
                    </div>
                </button>
            `;
        }).join('');

        list.querySelectorAll('.stage-row').forEach((el) => {
            el.addEventListener('click', () => {
                const id = Number((el as HTMLElement).dataset.stageId);
                if (!isStageUnlocked(id, highestStageCleared)) return;
                selectedStageId = id;
                renderStageList();
                updateDeployButton();
            });
        });
    }

    async function loadArenaStatus() {
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) return;
        const { data: profile } = await supabase
            .from('profiles')
            .select('energy, max_energy, energy_updated_at, highest_stage_cleared')
            .eq('id', user.id)
            .single();
        if (!profile) return;

        highestStageCleared = profile.highest_stage_cleared;
        selectedStageId = Math.min(highestStageCleared + 1, STAGES[STAGES.length - 1].id);

        const regen = computeRegen(profile.energy, profile.max_energy, new Date(profile.energy_updated_at), new Date());
        renderStageList();
        renderEnergy(regen.newEnergy, profile.max_energy);
    }

    loadArenaStatus();

    function toRenderUnit(unit: PublicUnit): RenderUnit {
        return { ...unit, currentHp: unit.maxHp, isDead: false };
    }

    // --- VISUAL FX (unchanged from the original manual arena) ---
    function showFloatingText(targetId: string, text: string, type: "damage" | "crit" | "heal" = "damage") {
        const targetEl = document.getElementById(targetId);
        if (!targetEl) return;

        const rect = targetEl.getBoundingClientRect();
        const floater = document.createElement("div");

        let colorClass = "text-white";
        let sizeClass = "text-5xl";
        let glowClass = "drop-shadow-[0_0_10px_rgba(255,255,255,0.5)]";

        if (type === "crit") {
            colorClass = "text-gold-400";
            sizeClass = "text-8xl";
            glowClass = "drop-shadow-[0_0_20px_rgba(230, 162, 60,0.8)]";
            cameraShake(15);
        } else if (type === "heal") {
            colorClass = "text-green-400";
            sizeClass = "text-4xl";
            glowClass = "drop-shadow-[0_0_10px_rgba(74,222,128,0.5)]";
        } else if (type === "damage") {
            colorClass = "text-red-500";
            glowClass = "drop-shadow-[0_0_15px_rgba(239,68,68,0.5)]";
            cameraShake(5);
        }

        floater.className = `fixed font-teko font-black z-[200] pointer-events-none transition-all duration-1000 ${colorClass} ${sizeClass} ${glowClass} italic tracking-tighter`;
        floater.innerText = text;

        floater.style.left = `${rect.left + rect.width / 2}px`;
        floater.style.top = `${rect.top + rect.height / 3}px`;

        document.body.appendChild(floater);

        requestAnimationFrame(() => {
            floater.style.transform = "translate(-50%, -150px) scale(1.5) rotate(-10deg)";
            floater.style.opacity = "0";
        });

        setTimeout(() => floater.remove(), 1000);
    }

    function cameraShake(intensity = 5) {
        const scene = document.getElementById('battle-scene');
        if (!scene) return;
        scene.style.transform = `translate(${Math.random() * intensity - intensity/2}px, ${Math.random() * intensity - intensity/2}px)`;
        setTimeout(() => {
            if (scene) scene.style.transform = `translate(${Math.random() * intensity - intensity/2}px, ${Math.random() * intensity - intensity/2}px)`;
            setTimeout(() => { if (scene) scene.style.transform = ''; }, 50);
        }, 50);
    }

    // --- RENDERING ---
    function renderBattlefield() {
        const pContainer = document.getElementById('player-squad');
        const eContainer = document.getElementById('enemy-squad');
        if (pContainer) pContainer.innerHTML = playerSquad.map((u, i) => createCard(u, i, false)).join('');
        if (eContainer) eContainer.innerHTML = enemySquad.map((u, i) => createCard(u, i, true)).join('');
    }

    function createCard(unit: RenderUnit, index: number, isEnemy: boolean) {
        const cardId = isEnemy ? `e-unit-${index}` : `p-unit-${index}`;
        const hpPercent = (unit.currentHp / unit.maxHp) * 100;
        const grayscale = unit.isDead ? "grayscale opacity-40 brightness-50" : "";

        return `
            <div id="${cardId}" class="relative w-32 md:w-44 h-72 md:h-96 bg-black border border-white/5 rounded-3xl flex flex-col transition-all duration-300 group ${grayscale}">
                <div class="w-full h-48 md:h-64 relative rounded-t-[1.4rem] overflow-hidden">
                    <img src="${unit.image}" class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110" onerror="this.src='https://api.dicebear.com/7.x/adventurer/svg?seed=${unit.name}'">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
                    ${unit.isDead ? '<div class="absolute inset-0 bg-red-950/60 flex items-center justify-center text-red-500 font-teko text-6xl italic drop-shadow-2xl -rotate-12">DEFEAT</div>' : ''}
                    <div class="absolute bottom-2 left-2 flex gap-1">
                        <span class="px-1.5 py-0.5 bg-black/60 backdrop-blur-md rounded text-[8px] font-space font-black text-white border border-white/10 uppercase">${unit.rarity || 'R'}</span>
                    </div>
                </div>
                <div class="p-3 flex-1 flex flex-col justify-between bg-black/40 rounded-b-3xl">
                    <div>
                        <div class="text-[8px] text-gray-500 uppercase font-black tracking-widest">${unit.role || 'NAKAMA'}</div>
                        <div class="text-xl text-white font-teko uppercase leading-none tracking-tight">${unit.name}</div>
                    </div>
                    <div class="space-y-1.5 mt-2">
                        <div class="w-full h-1 bg-gray-900 rounded-full overflow-hidden">
                            <div class="bg-gradient-to-r from-green-600 to-green-400 h-full transition-all duration-500" style="width: ${hpPercent}%"></div>
                        </div>
                        <div class="flex justify-between text-[7px] font-space font-black text-gray-500 uppercase tracking-tighter">
                            <span>HP ${Math.ceil(unit.currentHp)}</span>
                        </div>
                    </div>
                </div>
            </div>
        `;
    }

    function log(text: string, type = "normal") {
        const logBox = document.getElementById('battle-log');
        if (!logBox) return;
        let color = 'text-gray-400';
        if (type === 'heal') color = 'text-green-400';
        if (type === 'crit') color = 'text-gold-400 font-black';

        logBox.innerHTML += `<div class="${color} border-b border-white/[0.02] pb-1">${text}</div>`;
        logBox.scrollTop = logBox.scrollHeight;
    }

    function updateUI(text: string, colorClass: string) {
        const el = document.getElementById('turn-indicator');
        if (el) {
            el.innerText = text;
            el.className = `font-teko text-4xl ${colorClass} uppercase tracking-widest drop-shadow-md`;
        }
    }

    function sleep(ms: number) {
        return new Promise((resolve) => setTimeout(resolve, ms));
    }

    // --- REPLAY THE SERVER-COMPUTED BATTLE LOG ---
    async function replayEvents(events: BattleEvent[]) {
        for (const event of events) {
            if (event.type === "action") {
                const squad = event.side === "player" ? playerSquad : enemySquad;
                const targetSquad = event.side === "player" ? enemySquad : playerSquad;
                const attacker = squad[event.attackerIndex];
                const target = targetSquad[event.targetIndex];
                const targetId = event.side === "player" ? `e-unit-${event.targetIndex}` : `p-unit-${event.targetIndex}`;

                target.currentHp = event.targetHpAfter;
                target.isDead = event.targetDied;

                if (event.skillType === "Ultimate") {
                    const scene = document.getElementById('battle-scene');
                    if (scene) {
                        scene.classList.add('brightness-200', 'scale-[1.02]');
                        setTimeout(() => scene.classList.remove('brightness-200', 'scale-[1.02]'), 100);
                    }
                }

                log(`${attacker.name} → ${event.skillName} → ${target.name}`, event.isCrit ? "crit" : "normal");
                renderBattlefield();
                showFloatingText(targetId, event.isCrit ? `CRITICAL! ${event.damage}` : `${event.damage}`, event.isCrit ? "crit" : "damage");

                await sleep(700);
            } else if (event.type === "heal") {
                const squad = event.side === "player" ? playerSquad : enemySquad;
                const target = squad[event.targetIndex];
                const healer = squad[event.healerIndex];
                const targetId = event.side === "player" ? `p-unit-${event.targetIndex}` : `e-unit-${event.targetIndex}`;

                target.currentHp = event.targetHpAfter;
                log(`${healer.name} heals ${target.name}!`, "heal");
                renderBattlefield();
                showFloatingText(targetId, `HEAL +${event.amount}`, "heal");

                await sleep(500);
            } else if (event.type === "battle_end") {
                return event.result;
            }
        }
        return "loss" as const;
    }

    function showResults(title: string, subtitle: string, colorClass: string) {
        const overlay = document.getElementById('results-overlay');
        const t = document.getElementById('result-title');
        const s = document.getElementById('result-subtitle');

        if (t) {
            t.innerText = title;
            t.className = `font-teko text-[12rem] leading-none tracking-tighter italic ${colorClass} drop-shadow-[0_0_50px_currentColor]`;
        }
        if (s) s.innerText = subtitle;

        if (overlay) {
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            overlay.classList.add('opacity-100', 'pointer-events-auto');
        }
    }

    async function startBattle() {
        const btn = document.getElementById('btn-start-battle') as HTMLButtonElement;
        const panel = document.getElementById('deploy-panel');
        btn.disabled = true;
        btn.innerText = "DEPLOYING...";
        updateUI("BATTLE IN PROGRESS", "text-gold-500 animate-pulse");

        let response: any;
        try {
            response = await callApi('/api/battle/start', { stageId: selectedStageId });
        } catch (err: any) {
            log(`SYSTEM: ${err.message}`, "crit");
            btn.disabled = false;
            btn.innerText = "DEPLOY SQUAD";
            updateUI("DEPLOYMENT FAILED", "text-red-500");
            return;
        }

        if (panel) panel.style.display = 'none';

        if (typeof response.newEnergy === 'number') {
            const maxEl = document.getElementById('energy-max');
            renderEnergy(response.newEnergy, Number(maxEl?.innerText) || response.newEnergy);
        }

        playerSquad = response.playerSquad.map(toRenderUnit);
        enemySquad = response.enemySquad.map(toRenderUnit);
        renderBattlefield();

        await sleep(500);
        const result = await replayEvents(response.events);

        if (result === "win") {
            updateUI("VICTORY", "text-gold-500");
            showResults("VICTORY", `+${response.berriesAwarded} BERRIES — THE GRAND LINE AWAITS YOUR COMMAND`, "text-gold-500");
        } else {
            updateUI("DEFEAT", "text-red-500");
            showResults("DEFEAT", "EVERY CAPTAIN HAS THEIR LOW TIDE", "text-red-500");
        }
    }

    document.getElementById('btn-start-battle')?.addEventListener('click', startBattle);
  </script>
</GameLayout>
