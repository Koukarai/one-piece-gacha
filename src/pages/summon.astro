---
import GameLayout from "../layouts/GameLayout.astro";
import GachaCard from "../components/GachaCard";
---

<GameLayout>
  <div class="flex flex-col items-center justify-center min-h-[80vh]">
    <div class="mb-8 text-center">
      <h2 class="font-['Teko'] text-5xl uppercase text-white">Summon Heroes</h2>
      <p class="font-['Space_Grotesk'] text-gray-400 text-sm tracking-widest">SPEND BERRY TO RECRUIT NEW NAKAMA</p>
    </div>
    <GachaCard client:load />
  </div>
</GameLayout>